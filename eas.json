{
  "cli": {
    "version": ">= 15.0.12",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "distribution": "internal"
      
    },
    "preview": {
      "distribution": "internal"
    },
    "staging": {
      "developmentClient": false,
      "distribution": "internal",
      "autoIncrement": true
    },
    "testing": {
      "developmentClient": false,
      "distribution": "internal",
      "autoIncrement": true
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store"
    }
  },
  "submit": {
    "production": {},
    "staging": {},
    "testing": {}
  }
}
